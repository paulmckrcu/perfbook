C C-SRCU-xdomain
//\begin[snippet][labelbase=ln:formal:C-SRCU-xdomain:whole,commandchars=\%\@\$]

{}

P0(int *x, int *y, struct srcu_struct *s1)
{
	int r1;
	int r2;
	int r3;

	r3 = srcu_read_lock(s1);
	r2 = READ_ONCE(*y);
	r1 = READ_ONCE(*x);
	srcu_read_unlock(s1, r3);
}

P1(int *x, int *y, struct srcu_struct *s2)
{
	WRITE_ONCE(*y, 1);
	synchronize_srcu(s2);
	WRITE_ONCE(*x, 1);
}

//\end[snippet]
locations [0:r1]
exists (0:r1=1 /\ 0:r2=0)
